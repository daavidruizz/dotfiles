{
  //MODULES LEFT
  "custom/archicon": {
    "format": " ’ŹÖ ",
    "on-click": "wofi --show drun",
    "tooltip": false
  },
  
  "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace m+1",
        "on-scroll-down": "hyprctl dispatch workspace m-1",
        "format-icons": {
              "urgent": "",
              "default": ""
          },
        "persistent-workspaces": {
              "DP-2": [1, 2, 3, 4, 5],
              "DP-3": [6, 7, 8, 9, 10]
          },
        "sort-by-number": true,
        "all-outputs": false
  },
  "custom/mail": {
    "format": " Ņ¼ø ",
    "on-click": "google-chrome-stable --app=https://outlook.live.com/mail/0/",
    "on-click-right": "google-chrome-stable --app=https://mail.google.com/mail/u/0/#inbox",
    "tooltip": false
  },
  //MODULES CENTER
  "hyprland/window": {
      "format": "{}",
      "max-length": 50,
      "tooltip": false
    },

  //MODULES RIGHT
    // Updates Count
    "custom/updates": {
        "format": "’å▓  {}",
        "escape": true,
        "return-type": "json",
        "exec": "~/.config/waybar/updates.sh",
        "interval": 1800,
        "signal": 1,
        "hide-empty-text": true,
        "on-click": "~/.config/waybar/lanzador-installupdates.sh"
      },
   // System
    "custom/system": {
        "format": "’Źå ",
        "tooltip": false
      },
    // CPU
    "cpu": {
        "format": "/ ’Æ╝  {usage}% ",
        "on-click": "~/.config/waybar/system-monitor.sh"
      },
    // Memory
    "memory": {
        "format": "/ Ņ┐ģ  {}% ",
        "on-click": "~/.config/waybar/system-monitor.sh"
      },
    // Harddisc space used
    "disk": {
        "interval": 30,
        "format": " / ¾░Ś« {percentage_used}% ",
        "path": "/",
        "on-click": "~/.config/waybar/system-monitor.sh"
      },
    "custom/cpu_temp": {
        "exec": "~/.config/waybar/cpu_temp.sh",
        "format": "­¤īĪ’ĖÅ {}┬░C",
        "interval": 5,
        "tooltip": false,
        "on-click": "~/.config/waybar/system-monitor.sh"
      },
    "custom/nvidia_gpu": {
        "exec": "~/.config/waybar/gpu_temp.sh",
        "format": "­¤Ä« {}┬░C",
        "interval": 5,
        "tooltip": false,
        "on-click": "~/.config/waybar/system-monitor.sh"
    },
    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
          },
        "modules": [
          "custom/system",
          "disk",
          "cpu",
          "memory",
          "custom/cpu_temp",
          "custom/nvidia_gpu",
          ]
        },
    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "’ć½ {signalStrength}%",
        "format-ethernet": " ¾░łĆ ",
        "format-disconnected": "Disconnected ŌÜĀ",
        "tooltip-format": "{ifname} via {gwaddri}",
        "tooltip-format-wifi": "’ć½  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "¾░łĆ  {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "~/.config/waybar/networkmanager.sh",
        "on-click-right": "~/.config/waybar/nm-applet.sh toggle",
      },
    // Pulseaudio
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "’æ” {icon}’Ŗö {format_source}",
        "format-muted": "’æ” {format_source}",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’Ćź ",
            "headset": "Ņ╣Ö ",
            "phone": "’éĢ ",
            "portable": "’éĢ ",
            "car": "’å╣ ",
            "default": [
                "’Ć”",
              "’Ć©",
              "’Ć©"
              ]
            },
        "on-click": "pavucontrol"
      },
      "bluetooth": {
        "format": "¾░é» {status}",
        "format-connected": "¾░é» {device_alias}",
        "format-connected-battery": "¾░é» {device_alias}",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "kitty --class=bluetuith -o background_opacity=1.0 -e bluetuith"
    },
    // Clock
    "clock": {
        "format": "{:%H:%M %a}",
        "on-click": "google-chrome-stable --app=https://calendar.google.com/calendar/u/0/r/month",
        "timezone": "",
        "tooltip": false
      },
    // System tray
    "tray": {
        "icon-size": 10,
        "spacing": 10
      },
  "custom/power": {
    "format": "ŌÅ╗",
    "on-click": "wlogout"
  }
}
